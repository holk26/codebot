# ============================================
# GitHub AI Agent - Environment Configuration
# ============================================

# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# Repository to monitor (format: owner/repo)
GITHUB_REPO=owner/repository

# LLM Provider Configuration (for nanobot analysis & opencode reasoning)
# Supported: openrouter, openai, anthropic, deepseek
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-your_key_here
LLM_MODEL=anthropic/claude-opus-4

# OpenCode Executor LLM (can be same or different)
OPENCODE_LLM_PROVIDER=openrouter
OPENCODE_LLM_API_KEY=sk-or-v1-your_key_here
OPENCODE_LLM_MODEL=anthropic/claude-opus-4

# Nanobot Configuration
NANOBOT_CONFIG_PATH=/app/config/nanobot.json

# Webhook Server
WEBHOOK_PORT=8080
WEBHOOK_HOST=0.0.0.0

# OpenCode Executor API
OPENCODE_API_PORT=8001
OPENCODE_API_HOST=0.0.0.0

# Redis
REDIS_URL=redis://redis:6379/0

# Workspace
WORKSPACE_DIR=/workspace

# Security
ALLOWED_ACTIONS=opened,reopened,edited
SKIP_LABEL=agent-skip

# Logging
LOG_LEVEL=INFO
