# ============================================
# GitHub AI Agent - Environment Configuration
# ============================================
# DEFAULT PROVIDER: Moonshot AI (月之暗面)
# Get your API key at: https://platform.moonshot.cn
# ============================================

# --- GENERATE STRONG SECRETS BEFORE FIRST RUN ---
# INTERNAL_API_KEY: openssl rand -hex 32
# REDIS_PASSWORD: openssl rand -hex 24
# GITHUB_WEBHOOK_SECRET: openssl rand -hex 32

# ============================================
# SECURITY SECRETS
# ============================================

# Shared secret for service-to-service authentication
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change_me_to_64_hex_chars

# Redis password (required)
# Generate: openssl rand -hex 24
REDIS_PASSWORD=change_me_to_48_hex_chars

# ============================================
# GITHUB
# ============================================

# GitHub Personal Access Token
# Scopes required: repo, write:discussion, read:org
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Webhook secret - MUST match GitHub webhook configuration
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=change_me_to_64_hex_chars

# GitHub App (optional, preferred over PAT for production)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# Repository to monitor (format: owner/repo)
GITHUB_REPO=owner/repository

# ============================================
# NANOBOT ORCHESTRATOR LLM
# ============================================
# Default provider: Moonshot AI
# Docs: https://platform.kimi.ai/playground
# Supported providers: moonshot, openrouter, openai, anthropic, deepseek, google, mistral

NANOBOT_LLM_PROVIDER=moonshot
NANOBOT_LLM_MODEL=kimi-k2.6

# Provider API Keys (fill the ones you use)
MOONSHOT_API_KEY=sk-your_moonshot_key_here
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# ============================================
# OPENCODE EXECUTOR LLM
# ============================================
# Can be same or different from Nanobot
# Default: Moonshot AI

OPENCODE_LLM_PROVIDER=moonshot
OPENCODE_LLM_API_KEY=sk-your_moonshot_key_here
OPENCODE_LLM_MODEL=kimi-k2.6

# ============================================
# OPENCODE WEB ACCESS (Basic Auth)
# ============================================
# If you want to expose OpenCode to the internet via Dokploy,
# set a strong password here. Access via browser with:
#   User: admin (or OPENCODE_WEB_USER)
#   Password: your OPENCODE_WEB_PASSWORD
# The /health endpoint remains open for load balancers.

OPENCODE_WEB_USER=admin
OPENCODE_WEB_PASSWORD=change_me_to_strong_password

# ============================================
# TELEGRAM INTEGRATION (Nanobot)
# ============================================
# 1. Create a bot with @BotFather on Telegram
# 2. Copy the bot token here
# 3. Start a chat with your bot
# 4. Nanobot will send issue/PR notifications

TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to interact with the bot.
# Use "*" (or leave empty) to allow everyone.
TELEGRAM_ALLOWED_USER_IDS=*

# ============================================
# OPTIONAL: DISCORD / SLACK
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# ============================================
# SERVICE CONFIG
# ============================================

# Nanobot Orchestrator
WEBHOOK_PORT=8080
WEBHOOK_HOST=0.0.0.0

# OpenCode Executor (internal only)
OPENCODE_API_PORT=8001
OPENCODE_API_HOST=0.0.0.0

# Workspace
WORKSPACE_DIR=/workspace

# Security
ALLOWED_ACTIONS=opened,reopened,edited
SKIP_LABEL=agent-skip

# Logging
LOG_LEVEL=INFO

# Nanobot config path
NANOBOT_CONFIG_PATH=/home/appuser/.nanobot/config.json
